    "pg": "^8.11.0",
    "ws": "^8.17.0",
    "ethers": "^6.11.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "4.9.6",
    "hardhat": "^2.22.0",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
