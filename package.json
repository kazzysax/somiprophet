{
  "name": "somiprophet",
  "version": "2.0.0",
  "description": "SOMIPROPHET v2 \u2014 AI oracle on Somnia Reactivity with treasury-funded agents",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
